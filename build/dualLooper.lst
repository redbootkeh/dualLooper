 102:dualLooper.cpp **** // â”€â”€ LED helpers (manual PWM via oscillator value) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â
 103:dualLooper.cpp **** // We drive the LED pin high/low based on the oscillator brightness threshold.
 104:dualLooper.cpp **** static inline void SetLed(GPIO &pin, float brightness)
 105:dualLooper.cpp **** {
 106:dualLooper.cpp ****     // Simple threshold: >0.5 = on.  Gives a natural blink/pulse from the osc.
 107:dualLooper.cpp ****     pin.Write(brightness > 0.5f);
 108:dualLooper.cpp **** }
 109:dualLooper.cpp **** 
 110:dualLooper.cpp **** // â”€â”€ Speed mapping â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
 111:dualLooper.cpp **** static inline float KnobToSpeed(float v)
 112:dualLooper.cpp **** {
 113:dualLooper.cpp ****     // 0..0.5 â†’ -2x..1x,   0.5..1.0 â†’ 1x..2x
 114:dualLooper.cpp ****     return (v <= 0.5f) ? (v * 6.f - 2.f) : (v * 2.f);
 115:dualLooper.cpp **** }
 116:dualLooper.cpp **** 
 117:dualLooper.cpp **** static inline float KnobToSteppedSpeed(float v)
 118:dualLooper.cpp **** {
 119:dualLooper.cpp ****     if(v < 0.05f) return -2.0f;
 120:dualLooper.cpp ****     if(v < 0.15f) return -1.5f;
 121:dualLooper.cpp ****     if(v < 0.25f) return -1.0f;
 122:dualLooper.cpp ****     if(v < 0.35f) return -0.5f;
 123:dualLooper.cpp ****     if(v < 0.45f) return  0.5f;
 124:dualLooper.cpp ****     if(v < 0.55f) return  1.0f;
 125:dualLooper.cpp ****     if(v < 0.70f) return  1.5f;
 126:dualLooper.cpp ****     if(v < 0.80f) return  2.0f;
 127:dualLooper.cpp ****     if(v < 0.90f) return  2.5f;
 128:dualLooper.cpp ****     return                3.0f;
 129:dualLooper.cpp **** }
 130:dualLooper.cpp **** 
 131:dualLooper.cpp **** static inline void ApplySpeed(varSpeedLooper &lp, float spd)
 132:dualLooper.cpp **** {
 133:dualLooper.cpp ****     lp.SetReverse(spd < 0.f);
 134:dualLooper.cpp ****     lp.SetIncrementSize(fabsf(spd));
 135:dualLooper.cpp **** }
 136:dualLooper.cpp **** 
