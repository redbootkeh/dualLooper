 253:varSpeedLooper.h ****     /** Initialize the buffer */
 254:varSpeedLooper.h ****     void InitBuff() { std::fill(&buff_[0], &buff_[buffer_size_ - 1], 0); }
 255:varSpeedLooper.h **** 
 256:varSpeedLooper.h ****     /** Get a floating point sample from the buffer */
 257:varSpeedLooper.h ****     inline const float Read(size_t pos) const { return buff_[pos]; }
 258:varSpeedLooper.h **** 
 259:varSpeedLooper.h ****     /** Reads from a specified point in the delay line using linear interpolation */
 260:varSpeedLooper.h ****     float ReadF(float pos)
 261:varSpeedLooper.h ****     {
 262:varSpeedLooper.h ****         float    a, b, frac;
 263:varSpeedLooper.h ****         uint32_t i_idx = static_cast<uint32_t>(pos);
 264:varSpeedLooper.h ****         frac           = pos - i_idx;
 265:varSpeedLooper.h ****         a              = buff_[i_idx];
 266:varSpeedLooper.h ****         b              = buff_[(i_idx + 1) % buffer_size_];
 267:varSpeedLooper.h ****         return a + (b - a) * frac;
 268:varSpeedLooper.h ****     }
 269:varSpeedLooper.h **** 
